          vertex="1" parent="1">
          <mxGeometry x="665" y="245" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ch-c" value="• SaaS direto + trial 30 dias&#xa;&#xa;• Parceria com cooperativas&#xa;&#xa;• Feiras: Agrishow,&#xa;  Show Rural Coopavel&#xa;&#xa;• Revendas de insumos"
          style="rounded=0;whiteSpace=wrap;html=0;fillColor=#f0f4f0;strokeColor=#c8e6c9;fontSize=9;verticalAlign=top;align=left;spacingTop=8;spacingLeft=8;"
