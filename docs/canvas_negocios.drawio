        <!-- ── SEGMENTOS DE CLIENTES ── -->
        <mxCell id="seg-h" value="Segmentos de Clientes"
          style="rounded=0;whiteSpace=wrap;html=0;fillColor=#1a4d1a;fontColor=#ffffff;strokeColor=#1a4d1a;fontStyle=1;fontSize=10;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="865" y="50" width="205" height="30" as="geometry" />
        </mxCell>
        <mxCell id="seg-c" value="• Médios produtores rurais&#xa;  (50–500 ha)&#xa;&#xa;• Grandes grupos agrícolas&#xa;  (múltiplas fazendas)&#xa;&#xa;• Cooperativas agrícolas&#xa;  (gestão coletiva)&#xa;&#xa;• Integradores de&#xa;  agronegócio"
          style="rounded=0;whiteSpace=wrap;html=0;fillColor=#f0f4f0;strokeColor=#c8e6c9;fontSize=9;verticalAlign=top;align=left;spacingTop=8;spacingLeft=8;"
          vertex="1" parent="1">
          <mxGeometry x="865" y="80" width="205" height="370" as="geometry" />
        </mxCell>

        <!-- ── ESTRUTURA DE CUSTOS ── -->
        <mxCell id="cost-h" value="Estrutura de Custos"
          style="rounded=0;whiteSpace=wrap;html=0;fillColor=#1a4d1a;fontColor=#ffffff;strokeColor=#1a4d1a;fontStyle=1;fontSize=10;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="50" y="455" width="510" height="30" as="geometry" />
        </mxCell>
        <mxCell id="cost-c" value="• Infraestrutura de nuvem (AWS / Azure): ~35% dos custos operacionais&#xa;• Equipe de P&amp;D (engenharia + agrônomos consultores): ~30%&#xa;• Suporte e Customer Success: ~15%&#xa;• Vendas e marketing (feiras, digital): ~12%&#xa;• Integrações e licenças de API: ~8%"
          style="rounded=0;whiteSpace=wrap;html=0;fillColor=#fff7ed;strokeColor=#fdba74;fontSize=9;verticalAlign=top;align=left;spacingTop=8;spacingLeft=8;"
          vertex="1" parent="1">
          <mxGeometry x="50" y="485" width="510" height="155" as="geometry" />
        </mxCell>

        <!-- ── FONTES DE RECEITA ── -->
        <mxCell id="rev-h" value="Fontes de Receita"
          style="rounded=0;whiteSpace=wrap;html=0;fillColor=#1a4d1a;fontColor=#ffffff;strokeColor=#1a4d1a;fontStyle=1;fontSize=10;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="560" y="455" width="510" height="30" as="geometry" />
        </mxCell>
        <mxCell id="rev-c" value="• SaaS Starter: R$ 299/mês — até 5 talhões&#xa;• SaaS Pro: R$ 799/mês — até 20 talhões&#xa;• Enterprise: sob consulta (grandes operações e cooperativas)&#xa;• Fee de implantação e customização: R$ 1.500 – 5.000&#xa;• Licenciamento de API para ERPs agrícolas e seguradoras"
          style="rounded=0;whiteSpace=wrap;html=0;fillColor=#f0fdf4;strokeColor=#86efac;fontSize=9;verticalAlign=top;align=left;spacingTop=8;spacingLeft=8;"
